{
  "name": "claudio-vscode",
  "displayName": "Claudio",
  "description": "Practical VS Code companion for Claudio with project-aware launch behavior and a real Control Center.",
  "version": "0.1.0",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:claudio.start",
    "onCommand:claudio.startInWorkspaceRoot",
    "onCommand:claudio.openDocs",
    "onCommand:claudio.openSetupDocs",
    "onCommand:claudio.openWorkspaceProfile",
    "onCommand:claudio.openControlCenter",
    "onCommand:claudio.newChat",
    "onCommand:claudio.openChat",
    "onCommand:claudio.resumeSession",
    "onCommand:claudio.abortChat",
    "onView:claudio.controlCenter",
    "onView:claudio.chat"
  ],
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "node_modules/ws/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "src/chat/**",
    "src/mcp/**",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "claudio.start",
        "title": "Claudio: Launch in Terminal",
        "category": "Claudio"
      },
      {
        "command": "claudio.startInWorkspaceRoot",
        "title": "Claudio: Launch in Workspace Root",
        "category": "Claudio"
      },
      {
        "command": "claudio.openDocs",
        "title": "Claudio: Open Repository",
        "category": "Claudio"
      },
      {
        "command": "claudio.openSetupDocs",
        "title": "Claudio: Open Setup Guide",
        "category": "Claudio"
      },
      {
        "command": "claudio.openWorkspaceProfile",
        "title": "Claudio: Open Workspace Profile",
        "category": "Claudio"
      },
      {
        "command": "claudio.openControlCenter",
        "title": "Claudio: Open Control Center",
        "category": "Claudio"
      },
      {
        "command": "claudio.newChat",
        "title": "Claudio: New Chat",
        "category": "Claudio"
      },
      {
        "command": "claudio.openChat",
        "title": "Claudio: Open Chat Panel",
        "category": "Claudio"
      },
      {
        "command": "claudio.resumeSession",
        "title": "Claudio: Resume Session",
        "category": "Claudio"
      },
      {
        "command": "claudio.abortChat",
        "title": "Claudio: Abort Generation",
        "category": "Claudio"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudio",
          "title": "Claudio",
          "icon": "media/claudio.svg"
        }
      ]
    },
    "views": {
      "claudio": [
        {
          "id": "claudio.chat",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "claudio.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "claudio.openChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ],
    "configuration": {
      "title": "Claudio",
      "properties": {
        "claudio.launchCommand": {
          "type": "string",
          "default": "claudio",
          "description": "Command run in the integrated terminal when launching Claudio."
        },
        "claudio.terminalName": {
          "type": "string",
          "default": "Claudio",
          "description": "Integrated terminal tab name for Claudio sessions."
        },
        "claudio.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally set CLAUDE_CODE_USE_OPENAI=1 in launched Claudio terminals."
        },
        "claudio.permissionMode": {
          "type": "string",
          "default": "acceptEdits",
          "enum": ["default", "acceptEdits", "bypassPermissions", "plan"],
          "enumDescriptions": [
            "Prompt for permission on each tool use (requires manual approval)",
            "Auto-approve file edits, prompt for other operations (recommended)",
            "Auto-approve all operations without prompting",
            "Read-only mode — no file modifications allowed"
          ],
          "description": "Permission mode for chat sessions. Controls which tool operations are auto-approved."
        }
      }
    },
    "themes": [
      {
        "label": "Claudio Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/Claudio-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "bun test ./src/",
    "lint": "node scripts/lint.js",
    "package": "npx --yes @vscode/vsce@^3 package"
  },
  "keywords": [
    "claudio",
    "terminal",
    "theme",
    "cli",
    "llm"
  ],
  "license": "MIT",
  "dependencies": {
    "ws": "^8.18.0"
  }
}
